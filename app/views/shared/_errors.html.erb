<% if errors.any? %>
  <div class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="errors">
    <ul>
      <% errors.each do |attribute, messages| %>
        <% messages.each do |message| %>
          <li><%= "#{attribute.to_s.humanize} #{message}" %></li>
        <% end %>
      <% end %>
    </ul>
  </div>
<% end %>

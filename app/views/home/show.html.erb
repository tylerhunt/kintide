<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl"><%= Current.account.circle.name %></h1>
  <p class="mt-2 text-gray-500">Welcome, <%= Current.account.name %></p>

  <div class="mt-8 flex items-center gap-4">
    <%= link_to "New post", new_post_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium" %>
    <%= link_to "Invite", new_subscription_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium" %>
    <%= link_to "Edit profile", edit_profile_path, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= button_to "Sign out", session_path, method: :delete, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium cursor-pointer" %>
  </div>

  <div class="mt-8 space-y-8" id="posts">
    <% if posts.any? %>
      <%= render partial: 'posts/post', collection: posts %>
    <% else %>
      <p class="text-gray-500">No posts yet. Share your first update!</p>
    <% end %>
  </div>

  <div class="mt-8" id="subscribers">
    <h2 class="font-bold text-2xl">Subscribers</h2>

    <% if subscriptions.any? %>
      <ul class="mt-4 space-y-2">
        <% subscriptions.each do |subscription| %>
          <li class="flex items-center gap-3">
            <span class="font-medium"><%= subscription.name %></span>
            <span class="text-gray-500"><%= subscription.phone_number %></span>
            <% if subscription.invited? %>
              <span class="py-0.5 px-2 bg-gray-100 text-gray-600 text-sm rounded-full">Invited</span>
              <%= button_to "Remove", remove_subscription_path(subscription.token), method: :delete, class: "text-sm text-gray-500 underline hover:no-underline cursor-pointer" %>
            <% elsif subscription.active? %>
              <span class="py-0.5 px-2 bg-green-50 text-green-600 text-sm rounded-full">Subscribed</span>
            <% else %>
              <span class="py-0.5 px-2 bg-gray-100 text-gray-600 text-sm rounded-full">Unsubscribed</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-4 text-gray-500">No subscribers yet. Invite someone close.</p>
    <% end %>
  </div>
</div>

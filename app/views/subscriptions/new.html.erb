<div class="mx-auto md:w-2/3 w-full">
  <%= render 'shared/errors', errors: local_assigns.fetch(:errors, {}) %>

  <h1 class="font-bold text-4xl">Invite a subscriber</h1>

  <%= form_with url: subscriptions_path, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :name, "Name", class: "block font-medium" %>
      <%= form.text_field :name, required: true, autofocus: true, placeholder: "Enter their name", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="my-5">
      <%= form.label :phone_number, "Phone number", class: "block font-medium" %>
      <%= form.telephone_field :phone_number, required: true, autocomplete: "tel", placeholder: "Enter their phone number", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="inline">
      <%= form.submit "Send invitation", class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>

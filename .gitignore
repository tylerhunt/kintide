# bundler config
/.bundle

# logfiles and tempfiles
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# ignore pidfiles, but keep the directory
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# storage (uploaded files in development and any SQLite databases)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# generated assets
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# key files for decrypting credentials and more
/config/*.key

# developer-specific configuration files
/.bates
/.claude/settings.local.json
/.env*
/.rspec-local
/spec/examples.txt

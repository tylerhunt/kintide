<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">You’re invited</h1>

  <p class="mt-4">
    <%= subscription.circle.account.name %> invited you to follow
    <strong><%= subscription.circle.name %></strong> on Kintide. You’ll get
    a text whenever there’s a new update.
  </p>

  <div class="mt-8">
    <%= button_to "Accept invitation", accept_subscription_path(subscription.token), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
</div>
